{
	"name": "logger/ntfy",
	"description": "Ntfy client and PSR logger integration",
	"license": "proprietary",
	"require": {
		"php": ">=8.1",
		"psr/http-client": "^1.0",
		"psr/http-factory": "^1.1",
		"psr/http-message": "^2.0",
		"psr/log": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"Logger\\Ntfy\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Logger\\Ntfy\\Tests\\": "tests/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5"
	},
	"scripts": {
		"test": "phpunit -c tests.xml"
	}
}
