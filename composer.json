{
	"name": "logger/ntfy",
	"description": "Ntfy client and PSR logger integration",
	"license": "proprietary",
	"require": {
		"php": ">=8.1",
		"psr/http-client": ">= 1.0",
		"psr/http-factory": ">= 1.0",
		"psr/http-message": ">= 1.0",
		"psr/log": ">= 1.0"
	},
	"autoload": {
		"psr-4": {
			"Logger\\Ntfy\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Logger\\Ntfy\\Tests\\": "tests/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5",
		"guzzlehttp/guzzle": "^7.10",
		"phpstan/phpstan": "^2.1"
	},
	"scripts": {
		"test": "phpunit -c tests.xml",
		"phpstan": "phpstan analyse -c phpstan.neon"
	}
}
